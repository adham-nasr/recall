@startuml
title Component Diagram - Component Hierarchy

package "APP" {
    
    package "Home" {
        component Header
        component PracticeMethods
    }
    
    package "ProblemSet" {
        component Header as PSHeader
        package "CategoriesList" {
            ' Collection of CategoryCard components - shown as a single component with multiplicity
            component "CategoryCard" as CategoryCard
            note bottom: Multiple CategoryCard instances

        }
    }
    
    package "PracticePlayground" {
        component Title
        component Question
        component Choices
    }
}

' BaseCard is external/shared
component BaseCard

' Each CategoryCard uses BaseCard (dependency)
CategoryCard ..> BaseCard : uses

' Container relationships (composition)
App -down-> Home
App -down-> ProblemSet
App -down-> PracticePlayground

' Styling
skinparam component {
    BackgroundColor #E1F5FE
    BorderColor #0288D1
    FontSize 10
}

skinparam package {
    BackgroundColor #F3E5F5
    BorderColor #7B1FA2
    FontStyle bold
}

skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F57F17
}

@enduml